START:
MVI A,FFH ;LEDs OFF
STA 3000H
CALL CHECKLSB
JC START ;It exits this loop only when LSB=OFF

STEP1:
CALL CHECKLSB
JNC STEP1 ;It exits this loop only when LSB=ON

STEP2:
CALL CHECKLSB
JC STEP2 ;It continues only when LSB=OFF
MVI D,4BH ;75 cycles (15/0.2 s)

FLASH:
CALL LEDON
CALL DELAY
CALL LEDOFF
CALL DELAY
CALL CHECKLSB
JC TRIGERRED
DCR D
JZ START
JMP FLASH

TRIGERRED:
CALL LEDON
CALL DELAY
CALL LEDOFF
CALL DELAY
CALL CHECKLSB
JNC REFILL
DCR D
JZ START
JMP TRIGERRED

REFILL:
MVI D,4BH
JMP FLASH

CHECKLSB:
LDA 2000H ;Input from dip switch
RRC ;Get LSB
RET

DELAY:
MVI E,15H
DELAY1:
MVI C,FFH
DELAY2:
DCR C
JNZ DELAY2
DCR E
JNZ DELAY1
RET

LEDON:
MVI A,00H
STA 3000H
RET

LEDOFF:
MVI A,FFH
STA 3000H 
RET

END