PRINT:             ; Print the keycode that was pressed
LXI D,0B62H        ; Load HL with the address of the storage location
MVI A,FFH          ; Load A with FFH 
CALL STDM          ; Call STDM 
PRINT2:            ; Large loop to keep the key pressed on the display
CALL DCD           ; Call DCD 
DCR A              ; Decrement A
JNZ PRINT2         ; Repeat the loop until A reaches 0
JMP START          ; Restart the process to check for the next input

END


